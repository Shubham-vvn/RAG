# ──────────────────────────────────────────────────────────────────────────────
# .env.example  —  Copy this file to .env and fill in your real values.
#                  NEVER commit .env to source control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Groq LLM ─────────────────────────────────────────────────────────────────
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Primary model for ranking + explanation (strong reasoning)
GROQ_MODEL=llama-3.3-70b-versatile

# Fallback model for dev/testing (faster, cheaper)
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

# Inference temperature — keep low for consistent JSON output
GROQ_TEMPERATURE=0.3

# ── Data ──────────────────────────────────────────────────────────────────────
# Local path to cache the Hugging Face dataset (avoids re-downloading)
DATA_CACHE_PATH=./data/zomato_cache.parquet

# Hugging Face dataset identifier (change only if dataset is forked/moved)
HF_DATASET_NAME=ManikaSaini/zomato-restaurant-recommendation

# Optional: HuggingFace token if dataset requires authentication
# HF_TOKEN=your_huggingface_token_here

# ── Filter Settings ───────────────────────────────────────────────────────────
# Maximum restaurants sent to Groq LLM (controls token cost)
MAX_CANDIDATES_FOR_LLM=20

# Number of top recommendations to display to the user
TOP_K_RECOMMENDATIONS=5
